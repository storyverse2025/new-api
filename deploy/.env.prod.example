# ============================================================
# SV Gateway — Production Environment Template
# Copy to .env.prod and fill in all CHANGE_ME / placeholder values.
# NEVER commit .env.prod — it is gitignored.
# ============================================================

# ── Server ───────────────────────────────────────────────────
PORT=3000
TZ=Asia/Shanghai
ERROR_LOG_ENABLED=true
BATCH_UPDATE_ENABLED=true
NODE_NAME=sv-gateway-prod-1

# ── Domain / Frontend ────────────────────────────────────────
GATEWAY_DOMAIN=gateway.storyverseai.art
FRONTEND_BASE_URL=https://gateway.storyverseai.art

# ── Security secrets ─────────────────────────────────────────
# Generate with: openssl rand -hex 32
SESSION_SECRET=CHANGE_ME
# CRYPTO_SECRET encrypts channel API keys at rest in the DB.
# WARNING: Never change this after channels have been created —
# existing channel keys will become unreadable.
CRYPTO_SECRET=CHANGE_ME

# ── Main database (Supabase) ─────────────────────────────────
# Use the Supabase SESSION pooler (port 5432, IPv4-compatible),
# NOT the transaction pooler (port 6543) — GORM uses prepared
# statements which are incompatible with the transaction pooler.
# Always append ?sslmode=require.
# Example: postgresql://postgres.<ref>:<password>@<region>.pooler.supabase.com:5432/postgres?sslmode=require
SQL_DSN=postgresql://postgres.<ref>:CHANGE_ME@<region>.pooler.supabase.com:5432/postgres?sslmode=require

# ── Log database (separate Supabase project, recommended) ────
# The request_logs table (Plan H) grows fast with prompt content.
# Route it to a separate Supabase project (or any Postgres) to
# keep analytics writes off the main OLTP DB.
# If left empty, logs fall back to the main DB (SQL_DSN).
# Same rules: Session pooler, port 5432, ?sslmode=require.
LOG_SQL_DSN=postgresql://postgres.<ref>:CHANGE_ME@<region>.pooler.supabase.com:5432/postgres?sslmode=require

# ── Redis ────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
REDIS_PASSWORD=CHANGE_ME
REDIS_CONN_STRING=redis://:CHANGE_ME@redis:6379/0

# ── Media / stream capacity ──────────────────────────────────
MAX_REQUEST_BODY_MB=128
STREAM_SCANNER_MAX_BUFFER_MB=256
STREAMING_TIMEOUT=600
# 0 = no timeout on relay (let upstream decide)
RELAY_TIMEOUT=0

# ── Caching / sync ───────────────────────────────────────────
MEMORY_CACHE_ENABLED=true
# Seconds between full option syncs from DB to in-memory cache
SYNC_FREQUENCY=60
# Seconds between channel state syncs from DB
CHANNEL_UPDATE_FREQUENCY=30

# ── Request content logging (Plan H) ─────────────────────────
REQUEST_CONTENT_LOG_ENABLED=true

# ===== UPSTREAM KEYS (used by seed script, not by the container) =====
# These are read by deploy/seed_channels.sh to provision channels.
# The gateway container itself does NOT need them at runtime
# (keys are stored encrypted in the DB after seeding).
TOKENROUTER_API_KEY=
APIMART_API_KEY=
BYTEPLUS_ARK_API_KEY=
BYTEPLUS_ACCESS_KEY=
BYTEPLUS_SECRET_KEY=
BYTEPLUS_GROUP_ID=
SEEDREAM_LITE_ENDPOINT_ID=
SEEDANCE_20_ENDPOINT_ID=
MINIMAX_API_KEY=
ELEVENLABS_API_KEY=
FAL_KEY=

# ── Gateway bootstrap credentials ───────────────────────────
# Set these after the first boot / admin setup, then run seed_channels.sh.
GATEWAY_ROOT_PASSWORD=
GATEWAY_ROOT_ACCESS_TOKEN=
