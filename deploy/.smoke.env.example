# deploy/.smoke.env  —  copy this to deploy/.smoke.env and fill in.
# Only TWO values are needed; upstream provider keys live inside the gateway already.

# Gateway base URL (no trailing slash). e.g. https://gateway.storyverseai.art  or  http://localhost:3000
GATEWAY_URL=

# A group access token key (the "sk-..." created by seed_channels.sh: sv-monorepo-token or bragi-canvas-token)
SV_TOKEN=

# ── Optional knobs ────────────────────────────────────────────────
# Set to 1 to skip the (only) paid video call.
SKIP_VIDEO=0
# Override the video submit body if you want it even shorter/cheaper, or if the default fields are rejected.
# VIDEO_BODY={"model":"sv-video-seedance","prompt":"a red dot","duration":5,"resolution":"480p"}
# Max seconds to wait for the async video to finish before giving up.
VIDEO_POLL_TIMEOUT=360
