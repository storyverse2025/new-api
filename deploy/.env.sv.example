# --- runtime ---
PORT=3000
TZ=Asia/Shanghai
ERROR_LOG_ENABLED=true
BATCH_UPDATE_ENABLED=true
NODE_NAME=sv-gateway-node-1
FRONTEND_BASE_URL=https://gateway.storyverseai.art

# --- secrets (generate with: openssl rand -hex 32) ---
SESSION_SECRET=CHANGE_ME
CRYPTO_SECRET=CHANGE_ME

# --- database (Postgres) ---
POSTGRES_USER=sv_gateway
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=sv_gateway
SQL_DSN=postgresql://sv_gateway:CHANGE_ME@postgres:5432/sv_gateway

# --- redis ---
REDIS_PASSWORD=CHANGE_ME
REDIS_CONN_STRING=redis://:CHANGE_ME@redis:6379/0

# --- media / streaming limits (image/video/audio payloads) ---
MAX_REQUEST_BODY_MB=128
STREAM_SCANNER_MAX_BUFFER_MB=256
STREAMING_TIMEOUT=600
RELAY_TIMEOUT=0

# --- sync ---
MEMORY_CACHE_ENABLED=true
SYNC_FREQUENCY=60
CHANNEL_UPDATE_FREQUENCY=30

# --- request content logging (persists prompt/response to request_logs in LOG_DB) ---
REQUEST_CONTENT_LOG_ENABLED=true
